                "groupSlug": "contentText",
                "label": "Button Text",
                "priority": 10,
                "render": true,
                "subName": "text",
                "features": {
                  "dynamicContent": {
                    "type": "text"
                  },
                  "sticky": false,
                  "preset": "content"
                },
                "component": {
                  "name": "divi/text",
                  "type": "field"
                }
              }
            },
            "link": {
              "groupType": "group-item",
