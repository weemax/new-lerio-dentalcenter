    "packages": {
      "type": "object",
      "settings": {
        "innerContent": {
          "groupType": "group-item",
          "item": {
            "groupSlug": "shortcodeOptions",
            "priority": 60,
            "render": true,
            "attrName": "packages.innerContent",
