                "priority": 20,
                "render": false,
                "component": {
                  "type": "group",
                  "name": "divi/button-link",
                  "props": {
                    "grouped": false,
                    "attrName": "button.innerContent",
                    "fieldLabel": "Button"
                  }
                }
              }
            }
          }
        },
        "decoration": {
          "text": {},
          "border": {},
          "boxShadow": {},
          "button": {},
          "font": {},
          "spacing": {},
          "sizing": {},
          "filters": {},
          "transform": {},
          "animation": {}
        }
      }
    },
