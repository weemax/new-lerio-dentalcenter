{
    "name": "melograno/usage-tracker",
    "description": "WordPress plugin usage telemetry for Melograno products",
    "type": "library",
    "license": "proprietary",
    "version": "1.1.0",
    "require": {
        "php": ">=7.4"
    },
    "autoload": {
        "psr-4": {
            "Melograno\\UsageTracker\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Melograno\\UsageTracker\\Tests\\": "tests/"
        }
    },
    "require-dev": {
        "phpunit/phpunit": "^9.6",
        "brain/monkey": "^2.6"
    },
    "scripts": {
        "test": "phpunit"
    },
    "config": {
        "sort-packages": true,
        "platform": {
            "php": "7.4"
        }
    }
}
